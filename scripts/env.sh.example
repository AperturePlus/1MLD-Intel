#!/usr/bin/env bash
# Environment injection template (static).
# Usage: source scripts/env.sh
# Rule: keep export VAR= form and fill values as needed.
# Note: comment out a line if you want Spring to use application*.yml default.

export IMLD_ACTIVATION_CODE= # default: (empty); purpose: activation code used by private-edition license activation.
export IMLD_ACTIVATION_REQUIRED= # default: true; purpose: whether private deployment must pass activation before startup.
export IMLD_ACTIVATION_STATE_FILE_PATH= # default: /opt/imld/license/activation-state.json; purpose: local path storing activation state.
export IMLD_AUDIT_DEFAULT_PAGE_SIZE= # default: 20; purpose: default page size for audit query API.
export IMLD_AUDIT_ENABLED= # default: true; purpose: global switch for audit logging.
export IMLD_AUDIT_FAIL_CLOSED= # default: true; purpose: deny operation when audit logging fails.
export IMLD_AUDIT_MASKING_ENABLED= # default: true; purpose: mask sensitive fields in audit records.
export IMLD_AUDIT_MAX_PAGE_SIZE= # default: 200; purpose: max allowed page size for audit query API.
export IMLD_AUDIT_MAX_PAYLOAD_BYTES= # default: 8192; purpose: max payload bytes retained per audit event.
export IMLD_AUDIT_QUERY_API_ENABLED= # default: true; purpose: enables audit query endpoints.
export IMLD_AUDIT_QUERY_ROLE_ALLOWLIST= # default: SYSTEM_ADMIN,COMPLIANCE_AUDITOR; purpose: roles allowed to query audit data.
export IMLD_CLOUD_BRIDGE_ENABLED= # default: false; purpose: enables outbound cloud bridge capability.
export IMLD_DATA_ENCRYPTION_KEY= # default: (empty); purpose: key used for sensitive data encryption/decryption.
export IMLD_DB_DRIVER= # default: org.postgresql.Driver; purpose: JDBC driver class for primary database.
export IMLD_DB_PASSWORD= # default: imldintel; purpose: database password.
export IMLD_DB_URL= # default: jdbc:postgresql://localhost:5432/imld_core?sslmode=disable&characterEncoding=utf8; purpose: JDBC connection URL for primary database.
export IMLD_DB_USERNAME= # default: imld_user; purpose: database username.
export IMLD_DEPLOYMENT_MODE= # default: saas; purpose: runtime deployment mode, e.g. saas or private.
export IMLD_JWT_ACCESS_TOKEN_TTL= # default: 15m; purpose: JWT access token lifetime.
export IMLD_JWT_CLOCK_SKEW= # default: 30s; purpose: allowed clock skew during JWT validation.
export IMLD_JWT_ISSUER= # default: imld-intelligence; purpose: JWT issuer claim value.
export IMLD_JWT_REFRESH_TOKEN_TTL= # default: 7d; purpose: JWT refresh token lifetime.
export IMLD_JWT_SECRET= # default: (empty); purpose: JWT signing secret.
export IMLD_LICENSE_FILE_PATH= # default: /opt/imld/license/license.json; purpose: signed license file path.
export IMLD_LICENSE_MODEL= # default: saas-subscription; purpose: license model identifier.
export IMLD_LICENSE_PUBLIC_KEY_FILE_PATH= # default: /opt/imld/license/public.pem; purpose: public key path used to verify license signature.
export IMLD_MACHINE_BINDING_ENABLED= # default: true; purpose: enforces license machine binding check.
export IMLD_MTLS_REQUIRED= # default: true; purpose: requires mTLS for bridge communication.
export IMLD_PRIVATE_BUSINESS_MODEL= # default: buyout; purpose: private edition business model label.
export IMLD_PRIVATE_STARTUP_VALIDATION_ENABLED= # default: false; purpose: enables private startup license validation.

export IMLD_RABBITMQ_ACK_MODE= # default: manual; purpose: consumer acknowledgement mode.
export IMLD_RABBITMQ_CONSUMER_RETRY_ENABLED= # default: true; purpose: enables retry for RabbitMQ consumers.
export IMLD_RABBITMQ_CONSUMER_RETRY_INITIAL_INTERVAL= # default: 500ms; purpose: initial retry interval for consumers.
export IMLD_RABBITMQ_CONSUMER_RETRY_MAX_ATTEMPTS= # default: 3; purpose: max consumer retry attempts.
export IMLD_RABBITMQ_CONSUMER_RETRY_MULTIPLIER= # default: 2; purpose: exponential retry multiplier for consumers.
export IMLD_RABBITMQ_DEFAULT_REQUEUE_REJECTED= # default: false; purpose: whether rejected messages are requeued by default.
export IMLD_RABBITMQ_HOST= # default: localhost; purpose: RabbitMQ host.
export IMLD_RABBITMQ_PASSWORD= # default: guest; purpose: RabbitMQ password.
export IMLD_RABBITMQ_PORT= # default: 5672; purpose: RabbitMQ port.
export IMLD_RABBITMQ_PREFETCH= # default: 20; purpose: consumer prefetch count.
export IMLD_RABBITMQ_PRODUCER_RETRY_ENABLED= # default: true; purpose: enables retry for RabbitMQ producer operations.
export IMLD_RABBITMQ_PRODUCER_RETRY_INITIAL_INTERVAL= # default: 500ms; purpose: initial retry interval for producer operations.
export IMLD_RABBITMQ_PRODUCER_RETRY_MAX_ATTEMPTS= # default: 3; purpose: max producer retry attempts.
export IMLD_RABBITMQ_PRODUCER_RETRY_MULTIPLIER= # default: 2; purpose: exponential retry multiplier for producer operations.
export IMLD_RABBITMQ_SSL_ENABLED= # default: false; purpose: enables TLS for RabbitMQ connection.
export IMLD_RABBITMQ_TEMPLATE_MANDATORY= # default: true; purpose: mandatory publishing flag for undeliverable message handling.
export IMLD_RABBITMQ_USERNAME= # default: guest; purpose: RabbitMQ username.
export IMLD_RABBITMQ_VHOST= # default: /; purpose: RabbitMQ virtual host.

export IMLD_REDIS_CONNECT_TIMEOUT= # default: 2s; purpose: Redis connection establishment timeout.
export IMLD_REDIS_DATABASE= # default: 0; purpose: Redis logical database index.
export IMLD_REDIS_HOST= # default: localhost; purpose: Redis host.
export IMLD_REDIS_PASSWORD= # default: (empty); purpose: Redis password.
export IMLD_REDIS_PORT= # default: 6379; purpose: Redis port.
export IMLD_REDIS_SSL_ENABLED= # default: false; purpose: enables TLS for Redis connection.
export IMLD_REDIS_TIMEOUT= # default: 2s; purpose: Redis command timeout.

export IMLD_REPLAY_PROTECTION_ENABLED= # default: true; purpose: enables anti-replay protection on signed requests.
export IMLD_REQUEST_SIGNATURE_REQUIRED= # default: true; purpose: requires request signature validation for bridge traffic.
export IMLD_RESILIENCE_BH_MAX_CONCURRENT_CALLS= # default: 25; purpose: max concurrent calls for semaphore bulkhead.
export IMLD_RESILIENCE_BH_MAX_WAIT= # default: 0; purpose: max wait duration for semaphore bulkhead admission.
export IMLD_RESILIENCE_CB_FAILURE_RATE= # default: 50; purpose: circuit breaker failure rate threshold percentage.
export IMLD_RESILIENCE_CB_HALF_OPEN_CALLS= # default: 5; purpose: allowed calls while circuit breaker is half-open.
export IMLD_RESILIENCE_CB_MIN_CALLS= # default: 10; purpose: minimum calls before circuit breaker computes failure rate.
export IMLD_RESILIENCE_CB_SLOW_CALL_DURATION= # default: 2s; purpose: duration threshold used to classify slow calls.
export IMLD_RESILIENCE_CB_SLOW_CALL_RATE= # default: 70; purpose: slow call rate threshold percentage.
export IMLD_RESILIENCE_CB_WAIT_OPEN= # default: 30s; purpose: open-state wait duration before trying half-open.
export IMLD_RESILIENCE_CB_WINDOW_SIZE= # default: 20; purpose: circuit breaker sliding window size.
export IMLD_RESILIENCE_RETRY_BACKOFF_MULTIPLIER= # default: 2; purpose: exponential backoff multiplier for retries.
export IMLD_RESILIENCE_RETRY_MAX_ATTEMPTS= # default: 3; purpose: max retry attempts for resilience4j retry.
export IMLD_RESILIENCE_RETRY_MAX_WAIT= # default: 3s; purpose: max exponential backoff wait duration.
export IMLD_RESILIENCE_RETRY_WAIT= # default: 500ms; purpose: base retry wait duration.
export IMLD_RESILIENCE_RL_LIMIT_FOR_PERIOD= # default: 100; purpose: rate limiter allowed calls per refresh period.
export IMLD_RESILIENCE_RL_REFRESH_PERIOD= # default: 1s; purpose: rate limiter refresh period.
export IMLD_RESILIENCE_RL_TIMEOUT= # default: 0; purpose: rate limiter wait timeout for permission.
export IMLD_RESILIENCE_TIME_LIMITER_TIMEOUT= # default: 3s; purpose: time limiter timeout duration.
export IMLD_RESILIENCE_TPBH_CORE_POOL_SIZE= # default: 4; purpose: thread-pool bulkhead core pool size.
export IMLD_RESILIENCE_TPBH_MAX_POOL_SIZE= # default: 8; purpose: thread-pool bulkhead max pool size.
export IMLD_RESILIENCE_TPBH_QUEUE_CAPACITY= # default: 32; purpose: thread-pool bulkhead queue capacity.

export IMLD_SECURITY_ENABLED= # default: false; purpose: global application security switch.
export IMLD_SQL_INIT_MODE= # default: never; purpose: Spring SQL initialization mode.
export IMLD_SWAGGER_ENABLED= # default: true; purpose: enables OpenAPI docs endpoint.
export IMLD_SWAGGER_UI_ENABLED= # default: true; purpose: enables Swagger UI endpoint.
export IMLD_TENANT_MODE= # default: multi-tenant; purpose: tenant isolation mode.
export IMLD_UPGRADE_ALLOW_SECURITY_PATCH_AFTER_EXPIRY= # default: true; purpose: allows security patch upgrade after support expiry.
export IMLD_UPGRADE_CHECK_ENABLED= # default: false; purpose: enables upgrade check process.
export IMLD_UPGRADE_DELIVERY_MODE= # default: offline-package; purpose: upgrade package delivery strategy.
export IMLD_UPGRADE_ENFORCE_SUPPORT_WINDOW= # default: true; purpose: enforces support window for upgrade eligibility.
export IMLD_UPGRADE_MANIFEST_FILE_PATH= # default: (empty); purpose: path to signed upgrade manifest file.
export IMLD_UPGRADE_RELEASE_CHANNEL= # default: lts; purpose: preferred upgrade release channel.
